# Copy to Netlify → Site settings → Environment variables (or local .env)
# Never commit .env — it is gitignored.

# Firebase (Firebase Console → Project settings → Your apps → Web app config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Maps (Google Cloud Console → APIs & Services → Credentials)
# Restrict key: HTTP referrers = your domain(s) only; APIs = Maps JavaScript, Places, Geocoding
VITE_GOOGLE_MAPS_API_KEY=

# Public site URL for share links
VITE_SITE_URL=https://vjrestate.com
