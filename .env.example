# Copy to Netlify → Site settings → Environment variables (or local .env)
# Never commit .env — it is gitignored.

# Firebase (Firebase Console → Project settings → Your apps → Web app config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Google Maps Browser Key (Google Cloud Console → APIs & Services → Credentials)
# This key is PUBLIC (visible to browser) — MUST be restricted by HTTP referrer
# Restrict to HTTP referrers: https://www.vjrestate.com, https://vjrestate.com, http://localhost:5173*
# Enable APIs: Maps JavaScript API, Places API
VITE_GOOGLE_MAPS_API_KEY=

# Google Maps Server Key (Google Cloud Console → APIs & Services → Credentials)
# This key is PRIVATE — stored server-side only, NEVER in VITE_ env vars
# Restrict to IP: your Netlify deploy IP (or unrestricted in development)
# Enable APIs: Geocoding API, Places API (New)
GOOGLE_MAPS_SERVER_KEY=

# Public site URL for share links
VITE_SITE_URL=https://vjrestate.com

# Admin Firebase UID and email (override defaults from src/lib/adminAuth.ts)
VITE_ADMIN_UID=
VITE_ADMIN_EMAIL=

# ── Notion Sync ──────────────────────────────────────────────────────────────
# Create a Notion integration: https://www.notion.so/my-integrations
# Then share your database with the integration (Invite → your integration name)
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Sync endpoint security — set a random secret, pass as "Authorization: Bearer <secret>"
SYNC_SECRET=

# Firebase service account (base64 of the JSON key file)
# Get it: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Convert to base64: certutil -encode -f service-account.json tmp.b64 && type tmp.b64
# Or on Mac/Linux: cat service-account.json | base64
FIREBASE_SERVICE_ACCOUNT_KEY=

# Optional: override Notion column → Firestore field mapping (JSON)
# NOTION_COLUMN_MAPPING={"title":"Property Name","price":"Amount"}
