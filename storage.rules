rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'AhaNy8oyMHOFsB3u0dQhG0E0by43' ||
        request.auth.token.email == 'vijayramv229@gmail.com'
      );
    }

    match /properties/{uid}/{propertyId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }
  }
}
