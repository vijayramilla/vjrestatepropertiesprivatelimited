rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && (
        request.auth.uid == 'AhaNy8oyMHOFsB3u0dQhG0E0by43' ||
        request.auth.token.email == 'vijayramv229@gmail.com'
      );
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    function isValidLead() {
      return request.resource.data.keys().hasAll([
          'propertyId', 'propertyTitle', 'leadType', 'message', 'createdAt'
        ])
        && request.resource.data.propertyId is string
        && request.resource.data.propertyId.size() > 0
        && request.resource.data.propertyId.size() <= 128
        && request.resource.data.propertyTitle is string
        && request.resource.data.propertyTitle.size() <= 500
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && request.resource.data.leadType in ['whatsapp', 'book_visit']
        && (!('buyerName' in request.resource.data)
          || (request.resource.data.buyerName is string
            && request.resource.data.buyerName.size() <= 120))
        && (!('buyerPhone' in request.resource.data)
          || (request.resource.data.buyerPhone is string
            && request.resource.data.buyerPhone.size() <= 15));
    }

    function userCannotChangeSuspension() {
      return !('suspended' in request.resource.data)
        || request.resource.data.suspended == resource.data.get('suspended', false);
    }

    function isValidRequirementCreate() {
      return request.resource.data.keys().hasAll([
          'reqId', 'purpose', 'propertyType', 'locations',
          'budgetMin', 'budgetMax', 'timeline', 'status', 'clickCount'
        ])
        && request.resource.data.reqId is string
        && request.resource.data.purpose is string
        && request.resource.data.propertyType is string
        && request.resource.data.locations is list
        && request.resource.data.budgetMin is number
        && request.resource.data.budgetMax is number
        && request.resource.data.timeline is string
        && request.resource.data.status == 'open'
        && request.resource.data.clickCount == 0
        && !('paymentMode' in request.resource.data)
        && !('buyerName' in request.resource.data)
        && !('buyerPhone' in request.resource.data);
    }

    function isValidRequirementPrivateCreate() {
      return request.resource.data.keys().hasAll(['paymentMode', 'buyerName', 'buyerPhone'])
        && request.resource.data.paymentMode is string
        && request.resource.data.buyerName is string
        && request.resource.data.buyerName.size() > 0
        && request.resource.data.buyerName.size() <= 120
        && request.resource.data.buyerPhone is string
        && request.resource.data.buyerPhone.size() >= 10
        && request.resource.data.buyerPhone.size() <= 15;
    }

    function isValidClickCountIncrement() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['clickCount'])
        && request.resource.data.clickCount == resource.data.clickCount + 1;
    }

    match /requirements/{requirementId} {
      allow read: if true;
      allow create: if isAdmin() && isValidRequirementCreate();
      allow update: if isAdmin() || isValidClickCountIncrement();
      allow delete: if isAdmin();
    }

    match /requirement_private/{requirementId} {
      allow read, write: if isAdmin();
      allow create: if isAdmin() && isValidRequirementPrivateCreate();
    }

    match /properties/{propertyId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /property_leads/{leadId} {
      allow create: if isValidLead();
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow get, list: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isAdmin() || (isOwner(userId) && userCannotChangeSuspension());
      allow delete: if isAdmin();
    }
  }
}
